{
  "permissions": {
    "allow": [
      "Read(*)",
      "Search(*)",
      "WebSearch",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)"
    ], "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -Rf:*)",
      "Bash(rm -fR:*)"
    ],
    "defaultMode": "plan"
  }
}
